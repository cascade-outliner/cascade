{
  "name": "cascade-monorepo",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "pnpm --filter app db:push && pnpm --filter app --filter web --parallel run dev",
    "compile-messages": "pnpm --filter app compile-messages && pnpm --filter web compile-messages",
    "tsc": "pnpm compile-messages && pnpm --filter app exec tsc --noEmit && pnpm --filter web exec tsc --noEmit",
    "-----": "--------------------------",
    "dev:app": "pnpm --filter app dev",
    "generate-routes:app": "pnpm --filter app generate-routes",
    "build:app": "pnpm --filter app build",
    "preview:app": "pnpm --filter app preview",
    "test:app": "pnpm --filter app test",
    "test:e2e:app": "pnpm --filter app test:e2e",
    "test:perf:ui:app": "pnpm --filter app test:perf:ui",
    "start:app": "pnpm --filter app start",
    "db:generate:app": "pnpm --filter app db:generate",
    "db:migrate:app": "pnpm --filter app db:migrate",
    "db:push:app": "pnpm --filter app db:push",
    "db:pull:app": "pnpm --filter app db:pull",
    "db:seed:app": "pnpm --filter app db:seed",
    "db:seed:prod:app": "pnpm --filter app db:seed:prod",
    "start:seeded:app": "pnpm --filter app start:seeded",
    "db:studio:app": "pnpm --filter app db:studio",
    "perf:seed:app": "pnpm --filter app perf:seed",
    "perf:query:app": "pnpm --filter app perf:query",
    "perf:mutate:app": "pnpm --filter app perf:mutate",
    "perf:report:app": "pnpm --filter app perf:report",
    "------": "--------------------------",
    "dev:web": "pnpm --filter web dev",
    "generate-routes:web": "pnpm --filter web generate-routes",
    "build:web": "pnpm --filter web build",
    "preview:web": "pnpm --filter web preview",
    "test:web": "pnpm --filter web test",
    "start:web": "pnpm --filter web start",
    "----": "--------------------------",
    "format": "biome format",
    "format:write": "biome format --write",
    "lint": "biome lint",
    "check": "biome check"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "kysely": "0.28.17"
    }
  }
}
