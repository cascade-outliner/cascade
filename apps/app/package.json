{
  "name": "app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "vite dev --port 3001",
    "generate-routes": "tsr generate",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "start": "node ./src/db/migrate.ts && node ./.output/server/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:seed": "node --env-file=.env.local --import tsx/esm ./src/db/seed.ts",
    "db:seed:prod": "node --import tsx/esm ./src/db/seed.ts",
    "start:seeded": "pnpm db:seed:prod && pnpm start",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@cascade/auth": "workspace:*",
    "@cascade/outliner": "workspace:*",
    "@cascade/theme": "workspace:*",
    "@cascade/ui": "workspace:*",
    "@inlang/paraglide-js": "2.21.0",
    "@orpc/client": "^1.14.7",
    "@orpc/json-schema": "^1.14.7",
    "@orpc/openapi": "^1.14.7",
    "@orpc/server": "^1.14.7",
    "@orpc/tanstack-query": "^1.14.7",
    "@orpc/zod": "^1.14.7",
    "@phosphor-icons/react": "^2.1.10",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/router-plugin": "^1.168.19",
    "cva": "0.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fractional-indexing": "^4.0.0",
    "marked": "^18.0.5",
    "nitro": "3.0.260610-beta",
    "nuqs": "^2.9.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "srvx": "^0.11.21",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@inlang/plugin-message-format": "4.4.0",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/router-cli": "^1.167.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "lexical": "^0.46.0",
    "playwright": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
