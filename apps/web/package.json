{
  "name": "web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "node scripts/generate-sitemap.mjs && vite dev --port 3000",
    "generate-routes": "tsr generate",
    "compile-messages": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations",
    "build": "node scripts/generate-sitemap.mjs && vite build",
    "start": "node ./.output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@cascade/http": "workspace:*",
    "@cascade/outliner": "workspace:*",
    "@cascade/theme": "workspace:*",
    "@cascade/ui": "workspace:*",
    "@fontsource-variable/bitter": "^5.2.10",
    "@inlang/paraglide-js": "2.21.0",
    "@phosphor-icons/react": "^2.1.10",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/router-plugin": "^1.168.19",
    "marked": "^18.0.5",
    "nitro": "3.0.260610-beta",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@inlang/plugin-message-format": "4.4.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/router-cli": "^1.167.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}