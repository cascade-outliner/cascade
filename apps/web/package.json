{
  "name": "@cascade/web",
  "version": "1.0.0",
  "description": "Website template for Payload using TanStack Start",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --import ./src/register-style-imports.mjs\" vite build",
    "vercel-build": "payload migrate && cross-env NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --import ./src/register-style-imports.mjs\" vite build",
    "dev": "cross-env NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --import ./src/register-style-imports.mjs\" vite dev",
    "migrate": "cross-env NODE_OPTIONS=\"--no-deprecation --import ./src/register-style-imports.mjs\" payload migrate",
    "start": "cross-env NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --import ./src/register-style-imports.mjs\" vite preview",
    "generate:importmap": "cross-env NODE_OPTIONS=\"--no-deprecation --import ./src/register-style-imports.mjs\" payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=\"--no-deprecation --import ./src/register-style-imports.mjs\" payload generate:types",
    "payload": "cross-env NODE_OPTIONS=\"--no-deprecation --import ./src/register-style-imports.mjs\" payload",
    "lint": "eslint payload-tanstack-demo-main",
    "lint:fix": "eslint payload-tanstack-demo-main --fix",
    "ii": "pnpm --ignore-workspace install",
    "reinstall": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install"
  },
  "dependencies": {
    "@faceless-ui/window-info": "^3.0.1",
    "@payloadcms/admin-bar": "4.0.0-canary.13",
    "@payloadcms/db-postgres": "4.0.0-canary.13",
    "@payloadcms/drizzle": "4.0.0-canary.13",
    "@payloadcms/graphql": "4.0.0-canary.13",
    "@payloadcms/live-preview-react": "4.0.0-canary.13",
    "@payloadcms/next": "4.0.0-canary.13",
    "@payloadcms/plugin-form-builder": "4.0.0-canary.13",
    "@payloadcms/plugin-nested-docs": "4.0.0-canary.13",
    "@payloadcms/plugin-redirects": "4.0.0-canary.13",
    "@payloadcms/plugin-search": "4.0.0-canary.13",
    "@payloadcms/plugin-seo": "4.0.0-canary.13",
    "@payloadcms/richtext-lexical": "4.0.0-canary.13",
    "@payloadcms/storage-vercel-blob": "4.0.0-canary.13",
    "@payloadcms/tanstack-start": "4.0.0-canary.13",
    "@payloadcms/translations": "4.0.0-canary.13",
    "@payloadcms/ui": "4.0.0-canary.13",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-start": "1.168.26",
    "ajv": "8.20.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "console-table-printer": "2.15.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "drizzle-kit": "0.31.7",
    "drizzle-orm": "0.45.2",
    "fast-uri": "3.1.2",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "graphql-http": "^1.22.4",
    "libsql": "0.4.7",
    "lucide-react": "0.563.0",
    "nitro": "3.0.260610-beta",
    "payload": "4.0.0-canary.13",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "pluralize": "8.0.0",
    "prism-react-renderer": "^2.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "7.71.1",
    "scheduler": "^0.25.0",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "22.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.26",
    "autoprefixer": "^10.4.19",
    "playwright": "^1.61.1",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "react-server-dom-webpack": "^19.2.6",
    "sass": "^1.77.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "payload": "4.0.0-canary.13",
      "@payloadcms/ui": "4.0.0-canary.13",
      "@payloadcms/translations": "4.0.0-canary.13",
      "@payloadcms/richtext-lexical": "4.0.0-canary.13",
      "@payloadcms/drizzle": "4.0.0-canary.13",
      "@payloadcms/graphql": "4.0.0-canary.13",
      "@payloadcms/next": "4.0.0-canary.13",
      "@payloadcms/db-vercel-postgres": "4.0.0-canary.13",
      "@payloadcms/storage-vercel-blob": "4.0.0-canary.13",
      "@payloadcms/sdk": "4.0.0-canary.13",
      "@payloadcms/live-preview": "4.0.0-canary.13"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
