DATABASE_URL=postgres://postgres:postgres@localhost:5432/cascade
# Signs the session cookie. Only this app reads it (apps/website has no auth config of its own).
BETTER_AUTH_SECRET=change-me-to-a-random-string-of-32-plus-chars
# This app's own origin.
BETTER_AUTH_URL=http://localhost:3001
# Production only: set to .cascadelist.com so the session spans subdomains.
# COOKIE_DOMAIN=.cascadelist.com
# This app's own marketing/legal counterpart (apps/website).
VITE_WEB_URL=http://localhost:3000
PORT=3001
BETTER_AUTH_GITHUB_CLIENT_ID=
BETTER_AUTH_GITHUB_CLIENT_SECRET=
BETTER_AUTH_GOOGLE_CLIENT_ID=
BETTER_AUTH_GOOGLE_CLIENT_SECRET=
